UNITS LENGTH=A TIME=ps ENERGY=kcal/mol

d1: DISTANCE ATOMS=7198,7449
PRINT STRIDE=1 ARG=d1 FILE=COLVAR-d1.out

UPPER_WALLS ARG=d1 AT=5.0 KAPPA=500 LABEL=uwall
PRINT ARG=uwall.bias STRIDE=100 FILE=uwall.out

metad: METAD ARG=d1 PACE=20 HEIGHT=0.6 SIGMA=0.3 FILE=HILLS BIASFACTOR=20.0 TEMP=298.0
PRINT STRIDE=1 ARG=d1,metad.bias FILE=COLVAR-metad.out
